# API Configuration
INTERNAL_API_KEY=shared-secret-with-nestjs-backend
LOG_LEVEL=info

# CNAS Configuration
CNAS_BASE_URL=https://teledeclaration.cnas.dz
CNAS_VERIFY_PATH=/checkDECEMP.jsp
CNAS_CAPTCHA_PATH=/simpleCaptcha.png
CNAS_RATE_LIMIT_SECONDS=5
CAPTCHA_MAX_RETRIES=3

# Browser Pool Configuration
BROWSER_POOL_SIZE=2
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
PAGE_LOAD_TIMEOUT_MS=15000

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400

# CAPTCHA Fallback (Optional)
CAPTCHA_FALLBACK_2CAPTCHA=false
TWO_CAPTCHA_API_KEY=

# Form selectors (configurable in case site changes)
CNAS_FORM_ATTESTATION_SELECTOR=input[name="numAttestation"]
CNAS_FORM_EMPLOYER_SELECTOR=input[name="numEmployeur"]
CNAS_FORM_CAPTCHA_SELECTOR=input[name="captcha"]
CNAS_SUBMIT_SELECTOR=input[type="submit"]
