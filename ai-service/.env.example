# API Configuration
INTERNAL_API_KEY=shared-secret-with-nestjs-backend
OPENAI_API_KEY=sk-...
LOG_LEVEL=info

# Storage Configuration
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Agent Configuration
DEFAULT_CONFIDENCE_THRESHOLD=0.7
ENABLE_GPT4O_FALLBACK=true
MAX_SELF_CORRECTION_RETRIES=2

# Performance
WORKERS=2
MAX_FILE_SIZE_MB=20
