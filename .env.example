# API Keys (Unified Key for both services)
GEMINI_API_KEY=your-google-genai-key-here

# If you still want to use OpenAI for some reason, you can populate this, 
# but Gemini is now the default fallback.
OPENAI_API_KEY=

# Service Configuration
LOG_LEVEL=info
INTERNAL_API_KEY=shared-secret-with-nestjs-backend

# Agent Configuration
ENABLE_GEMINI_FALLBACK=true
ENABLE_GPT4O_FALLBACK=false
DEFAULT_CONFIDENCE_THRESHOLD=0.7
MAX_SELF_CORRECTION_RETRIES=2

# Storage (MinIO)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
